{
  "name": "bankshot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js --host 127.0.0.1",
    "dev:cloudflare": "npm run build && npx wrangler pages dev dist",
    "build": "node node_modules/typescript/bin/tsc -b && node node_modules/vite/bin/vite.js build",
    "deploy:cloudflare": "npm run build && npx wrangler pages deploy dist --project-name bankshot",
    "preview": "node node_modules/vite/bin/vite.js preview --host 127.0.0.1",
    "test": "node node_modules/vitest/vitest.mjs run"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
